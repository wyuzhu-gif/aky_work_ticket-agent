# ============================================================
# 作业票智能审查系统 - 配置文件
# 部署时请复制此文件为 .env 并修改配置项
#   cp .env.template .env
# ============================================================

# ---------- 基础设置 ----------
DEBUG=False
SERVE_STATIC=True
LOG_LEVEL=INFO
LOG_TO_FILE=True

# ---------- 本地存储 ----------
# PDF/图片等上传文档存放目录（相对路径基于 api/ 目录）
LOCAL_DOCS_DIR=./app/data/documents
# SQLite 数据库路径（存放审核记录、智能问数配置等）
SQLITE_PATH=./app/data/app.db

# ---------- MinerU 文档解析服务 ----------
# 方式一：使用云端 MinerU（需 API Key）
MINERU_BASE_URL=https://mineru.net
MINERU_API_KEY=                           # 云端 API Key，从 https://mineru.net 获取
# 方式二：使用本地部署 MinerU（优先级更高）
# 如果设置了 MINERU_LOCAL_URL，将优先使用本地 MinerU，无需 API Key
MINERU_LOCAL_URL=                         # 本地 MinerU 地址，如 http://192.168.1.100:38030
# MinerU 解析参数（一般无需修改）
MINERU_MODEL_VERSION=vlm
MINERU_BBOX_UNITS=px
MINERU_BBOX_CONTENT_COVERAGE=0.85
MINERU_MAX_WAIT_SEC=900

# ---------- LLM 大语言模型配置 ----------
# 作用：作业票审查的 AI 审核推理、智能问数的自然语言转SQL
#
# 支持两种部署方式：
# 【云端】使用阿里云 DashScope（通义千问）
#   LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
#   LLM_API_KEY=sk-xxxxx          # 从 https://dashscope.console.aliyun.com/ 获取
#   LLM_MODEL=qwen3.5-flash       # 推荐模型，性价比高
#   LLM_VISION_MODEL=qwen-vl-plus # 视觉模型，用于图片识别
#
# 【本地部署】使用 vLLM / Ollama 等推理框架
#   LLM_BASE_URL=http://你的IP:端口/v1
#   LLM_API_KEY=                  # 本地部署通常留空
#   LLM_MODEL=你的模型名称
#   LLM_VISION_MODEL=你的视觉模型名称
#
# 【其他云】DeepSeek、智谱、月之暗面等（OpenAI 兼容接口）
#   LLM_BASE_URL=https://api.deepseek.com/v1
#   LLM_API_KEY=sk-xxxxx
#   LLM_MODEL=deepseek-chat
#   LLM_VISION_MODEL=

LLM_API_KEY=                              # *** 必填 ***
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen3.5-flash
LLM_VISION_MODEL=qwen-vl-plus

# ---------- 法规知识库（LLM Wiki）----------
# 系统内置的法规知识库路径，包含国标/行标的结构化内容
# 部署包自带 wiki/ 目录，一般无需修改
WIKI_PATH=./wiki
WIKI_SEARCH_LIMIT=3

# ---------- 数据库 ----------
# 数据库类型 (当前仅支持 "mysql", PG 已迁移完成)
DB_TYPE=mysql
# 数据库 IP，如 10.8.0.100
DB_HOST=
# 端口 (MySQL 默认 3306)
DB_PORT=3306
# 数据库名
DB_DATABASE=special_operations
# 用户名
DB_USER=root
# 密码 *** 必填 ***
DB_PASSWORD=

# ---------- PostgreSQL 数据库 (已废弃, 保留仅为兼容) ----------
# 旧 PG 配置仍可读, 但代码已切换到 DB_* 系列; 新部署请填写上面的 DB_* 字段
# PG_HOST=
# PG_PORT=5432
# PG_DATABASE=special_operations
# PG_USER=postgres
# PG_PASSWORD=

# ---------- 智能问数 (SmartQuery NL2SQL) 专属配置 ----------
# 智能问数使用的 LLM（可以和上面 LLM 不同）
SQ_LLM_MODEL=qwen-flash                  # 推荐 qwen-flash（速度快、成本低）
SQ_LLM_TEMPERATURE=0.2
SQ_LLM_MAX_TOKENS=14000

# Embedding 向量服务（用于 SQL 训练数据的语义检索）
# 【Jina】自部署 Jina Embedding 服务
#   SQ_EMBEDDING_PROVIDER=jina
#   SQ_EMBEDDING_API_URL=http://你的IP:38898/v1/embeddings
#   SQ_EMBEDDING_API_KEY=
#   SQ_EMBEDDING_MODEL_NAME=
# 【通义】阿里云 DashScope Embedding
#   SQ_EMBEDDING_PROVIDER=qwen
#   SQ_EMBEDDING_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1/embeddings
#   SQ_EMBEDDING_API_KEY=sk-xxxxx
#   SQ_EMBEDDING_MODEL_NAME=text-embedding-v3
SQ_EMBEDDING_PROVIDER=jina
SQ_EMBEDDING_API_URL=                     # Embedding 服务地址，如 http://192.168.1.100:38898/v1/embeddings
SQ_EMBEDDING_API_KEY=
SQ_EMBEDDING_MODEL_NAME=

# Milvus 向量数据库（存储 SQL 训练数据的向量索引）
# 可以和 Embedding 服务部署在同一台机器
SQ_MILVUS_URI=                            # Milvus 地址，如 http://192.168.1.100:39530
SQ_MILVUS_METRIC_TYPE=COSINE
SQ_AGENT_RECURSION_LIMIT=500
